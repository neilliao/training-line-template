# ── intervals.icu（必填）──────────────────────────────
# Settings → API 取得 key；Athlete ID 在個人頁網址（i 開頭）
INTERVALS_API_KEY=
INTERVALS_ATHLETE_ID=

# ── LINE Messaging API（必填）─────────────────────────
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
LINE_USER_ID=

# ── Firebase（必填；本機用檔案路徑，Vercel/Actions 用 JSON 字串）──
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_PATH=./serviceAccountKey.json
# FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}

# ── Anthropic（建議：AI 分析與對話教練）────────────────
ANTHROPIC_API_KEY=

# ── 個人化 ───────────────────────────────────────────
ATHLETE_NAME=小明          # 你在教練課表中的名字
D4_LAT=25.0579             # 團練日訓練地點緯度（範例：台北松山）
D4_LON=121.5673            # 團練日訓練地點經度

# ── 選填 ─────────────────────────────────────────────
ICS_TOKEN=                 # /schedule.ics 日曆訂閱認證（未設則該端點 404）
MOENV_API_KEY=             # 台灣環境部 AQI（跑前評估空品用，非台灣可略）
GARTH_TOKEN=               # Garmin 直連（進階選配，見 AGENTS.md）
WELLNESS_COACH_API=        # 選配：wellness-dashboard-template 部署後的網址（沒有就不啟用）
WELLNESS_COACH_TOKEN=
